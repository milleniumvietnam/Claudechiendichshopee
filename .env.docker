# Docker Compose Environment File
# Copy to .env for docker-compose up

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kinh_doanh_shopee

# Node Environment
NODE_ENV=development

# Backend
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@db:5432/kinh_doanh_shopee
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5000

# Shopee API (Add your credentials)
SHOPEE_KEY=
SHOPEE_SECRET=
SHOPEE_PARTNER_ID=
SHOPEE_SHOP_ID=

# SePay (Add your credentials)
SEPAY_API_KEY=
SEPAY_SECRET_KEY=
SEPAY_MERCHANT_ID=

# Telegram (Add your credentials)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# JWT Secret (Generate: openssl rand -base64 32)
JWT_SECRET=dev-secret-key-change-in-production

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=Kinh Doanh Shopee
