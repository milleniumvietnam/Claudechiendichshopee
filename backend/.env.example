# ============================================
# Kinh Doanh Shopee - Environment Configuration
# ============================================

# Server
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/kinh_doanh_shopee
# Or use MongoDB: mongodb+srv://user:password@cluster.mongodb.net/database

# Shopee API
SHOPEE_KEY=your_shopee_app_key_here
SHOPEE_SECRET=your_shopee_app_secret_here
SHOPEE_SHOP_ID=your_shop_id_here
SHOPEE_PARTNER_ID=your_partner_id_here

# SePay (VietQR Payment)
SEPAY_API_KEY=your_sepay_api_key_here
SEPAY_SECRET_KEY=your_sepay_secret_key_here
SEPAY_MERCHANT_ID=your_merchant_id_here
SEPAY_WEBHOOK_URL=https://your-domain.com/api/payments/webhook

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_admin_chat_id_here

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Shopee Products Config
SHOPEE_CATEGORIES=phụ kiện điện thoại,smartwatch,pin sạc dự phòng
SHOPEE_MIN_RATING=4.5
SHOPEE_MIN_SALES=100
